# 애플리케이션
APP_NAME="객체 탐지 데이터셋 관리 솔루션"
DEBUG=false

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=dataset_pipeline

# 파일 저장 경로
UPLOADS_DIR=./data/uploads
EXPORTS_DIR=./data/exports
EMBEDDINGS_DIR=./data/embeddings

# CORS (프론트엔드 주소, 쉼표 구분)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Roboflow (선택)
ROBOFLOW_API_KEY=

# 임베딩 모델: resnet50 | clip
EMBEDDING_MODEL=resnet50
